* ANEXO: Esquema de Base de Datos

#+begin_src plantuml
@startuml : esquemadbs.png
!theme plain
entity "users" {
  * id : uuid
  --
  * email
  * created_at
}

entity "profiles" {
  * id : uuid (FK)
  --
  * username
  * plan
}

entity "favorites" {
  * id : uuid
  * user_id : uuid (FK)
  * country_code
  * created_at
}

entity "risk_alerts" {
  * id : uuid
  * country_code
  * old_risk
  * new_risk
  * created_at
}

entity "scraper_logs" {
  * id : uuid
  * source
  * status
  * created_at
}

users ||--o{ profiles
users ||--o{ favorites
@enduml
#+end_src