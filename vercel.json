{
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "viaje-con-inteligencia.vercel.app"
        }
      ],
      "destination": "https://www.viajeinteligencia.com/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "viajeinteligencia.com"
        }
      ],
      "destination": "https://www.viajeinteligencia.com/:path*",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "viaje-con-inteligencia.vercel.app"
        }
      ],
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow"
        }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/cron/master",
      "schedule": "0 6 * * *"
    }
  ]
}
