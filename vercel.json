{
  "headers": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "viaje-con-inteligencia.vercel.app"
        }
      ],
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow"
        }
      ]
    }
  ],

  "redirects": [
    {
      "source": "/(.*)",
      "destination": "https://viajeinteligencia.com/$1",
      "permanent": true
    }
  ],

  "crons": [
    {
      "path": "/api/cron/scrape-maec",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/check-alerts",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/weekly-digest",
      "schedule": "0 8 * * 1"
    },
    {
      "path": "/api/cron/daily-digest",
      "schedule": "0 0 * * *"
    }
  ]
}
